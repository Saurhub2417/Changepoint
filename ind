<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Change Point Detection — Himalayan Snowfall</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap');
  *{box-sizing:border-box;margin:0;padding:0}
  :root{
    --bg:#0d1117; --surface:#161b22; --surface2:#21262d;
    --border:#30363d; --text:#e6edf3; --muted:#8b949e;
    --pos:#3fb950; --neg:#f85149; --cusum:#58a6ff;
    --seg:#ffa657; --cp:#ff7b72; --decade:#484f58;
    --accent:#1f6feb;
  }
  body{background:var(--bg);color:var(--text);font-family:'EB Garamond',Georgia,serif;min-height:100vh;padding:0}
  h1{font-size:1.5rem;font-weight:600;letter-spacing:.01em;color:#e6edf3}
  h2{font-size:1.1rem;font-weight:400;font-style:italic;color:var(--muted);margin-top:.25rem}
  .header{padding:2rem 2.5rem 1rem;border-bottom:1px solid var(--border)}
  .header-meta{font-family:'JetBrains Mono',monospace;font-size:.72rem;color:var(--muted);margin-top:.5rem;letter-spacing:.05em}
  .tab-row{display:flex;gap:0;padding:0 2.5rem;border-bottom:1px solid var(--border);background:var(--surface)}
  .tab{padding:.6rem 1.4rem;cursor:pointer;font-size:.92rem;border-bottom:2px solid transparent;color:var(--muted);transition:all .2s;user-select:none;font-family:'EB Garamond',serif}
  .tab.active{color:var(--text);border-bottom-color:var(--accent)}
  .tab:hover:not(.active){color:var(--text)}
  .region-row{display:flex;flex-wrap:wrap;gap:.5rem;padding:1rem 2.5rem;border-bottom:1px solid var(--border);align-items:center}
  .region-btn{padding:.28rem .75rem;border-radius:20px;font-size:.82rem;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--muted);transition:all .18s;font-family:'EB Garamond',serif}
  .region-btn.active{color:#fff;border-color:transparent}
  .region-btn:hover{opacity:.85}
  .controls{display:flex;align-items:center;gap:1.2rem;padding:.75rem 2.5rem;border-bottom:1px solid var(--border);background:var(--surface);flex-wrap:wrap}
  .ctrl-label{font-size:.8rem;color:var(--muted);font-family:'JetBrains Mono',monospace}
  .btn{padding:.32rem .9rem;border-radius:6px;cursor:pointer;font-size:.85rem;border:1px solid var(--border);background:var(--surface2);color:var(--text);transition:all .15s;font-family:'EB Garamond',serif}
  .btn:hover{background:var(--accent);border-color:var(--accent)}
  .btn.primary{background:var(--accent);border-color:var(--accent);color:#fff}
  input[type=range]{-webkit-appearance:none;height:3px;background:var(--border);border-radius:2px;outline:none;width:140px}
  input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:14px;height:14px;border-radius:50%;background:var(--accent);cursor:pointer}
  .main{display:flex;height:calc(100vh - 230px);min-height:420px}
  .sidebar{width:220px;border-right:1px solid var(--border);padding:1rem;overflow-y:auto;flex-shrink:0}
  .sidebar-title{font-size:.75rem;font-family:'JetBrains Mono',monospace;color:var(--muted);letter-spacing:.08em;margin-bottom:.75rem;text-transform:uppercase}
  .stat-card{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:.7rem .9rem;margin-bottom:.6rem}
  .stat-label{font-size:.72rem;color:var(--muted);font-family:'JetBrains Mono',monospace;letter-spacing:.05em}
  .stat-value{font-size:1.05rem;font-weight:600;margin-top:.2rem;color:var(--text)}
  .cp-tag{display:inline-block;padding:.1rem .45rem;border-radius:4px;font-size:.72rem;font-family:'JetBrains Mono',monospace;background:rgba(255,123,114,.15);color:var(--cp);border:1px solid rgba(255,123,114,.3);margin:.1rem}
  .chart-area{flex:1;position:relative;overflow:hidden}
  canvas{display:block;position:absolute;top:0;left:0}
  .legend{display:flex;flex-wrap:wrap;gap:.9rem;padding:.6rem 2.5rem;border-top:1px solid var(--border);background:var(--surface);font-size:.78rem;align-items:center}
  .leg-item{display:flex;align-items:center;gap:.4rem;color:var(--muted)}
  .leg-swatch{width:22px;height:3px;border-radius:2px}
  .leg-swatch.bar-pos{height:12px;width:12px;border-radius:2px;background:var(--pos)}
  .leg-swatch.bar-neg{height:12px;width:12px;border-radius:2px;background:var(--neg)}
  .leg-swatch.cusum{background:var(--cusum);height:2px}
  .leg-swatch.seg{background:var(--seg);height:3px}
  .leg-swatch.cp{background:var(--cp);width:1px;height:14px}
  .leg-swatch.decade{background:var(--decade);height:2px;border-top:1px dashed var(--decade);background:transparent;width:22px;border-bottom:1px dashed var(--decade)}
  .progress-bar{height:2px;background:var(--accent);transition:width .1s linear;position:absolute;top:0;left:0}
  .tooltip{position:fixed;background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:.5rem .75rem;font-size:.8rem;font-family:'JetBrains Mono',monospace;pointer-events:none;opacity:0;transition:opacity .15s;z-index:100;color:var(--text)}
  .seg-change{font-size:.72rem;padding:.15rem .4rem;border-radius:3px;font-family:'JetBrains Mono',monospace}
  .seg-change.up{color:#3fb950;background:rgba(63,185,80,.1)}
  .seg-change.down{color:#f85149;background:rgba(248,81,73,.1)}
</style>
</head>
<body>

<div class="header">
  <h1>Change Point Detection — Himalayan Snowfall Anomaly</h1>
  <h2>PELT Algorithm · CUSUM Overlay · 1980–2020</h2>
  <div class="header-meta">STANDARDISED ANOMALY · NDJFM SEASON · METHOD: PRUNED EXACT LINEAR TIME (PELT, BIC)</div>
</div>

<div class="tab-row">
  <div class="tab active" onclick="switchDataset('state',this)">State / Country Level</div>
  <div class="tab" onclick="switchDataset('zonal',this)">Zonal / Macro Level</div>
</div>

<div class="region-row" id="region-row"></div>

<div class="controls">
  <button class="btn primary" id="play-btn" onclick="togglePlay()">▶ Play Animation</button>
  <button class="btn" onclick="resetAnim()">↺ Reset</button>
  <span class="ctrl-label">Speed</span>
  <input type="range" id="speed-range" min="1" max="8" value="4" oninput="updateSpeed(this.value)">
  <span class="ctrl-label" id="speed-label">4×</span>
  <span class="ctrl-label" style="margin-left:auto">
    Show: <label style="cursor:pointer;margin-left:.5rem"><input type="checkbox" id="show-cusum" checked onchange="redraw()"> CUSUM</label>
    <label style="cursor:pointer;margin-left:.75rem"><input type="checkbox" id="show-seg" checked onchange="redraw()"> Segment means</label>
  </span>
</div>

<div class="main">
  <div class="sidebar">
    <div class="sidebar-title">Statistics</div>
    <div id="stat-cards"></div>
  </div>
  <div class="chart-area" id="chart-area">
    <canvas id="c"></canvas>
    <div class="progress-bar" id="prog"></div>
  </div>
</div>

<div class="legend">
  <span class="leg-item"><span class="leg-swatch bar-pos"></span> Positive anomaly</span>
  <span class="leg-item"><span class="leg-swatch bar-neg"></span> Negative anomaly</span>
  <span class="leg-item"><span class="leg-swatch cusum" style="width:22px;height:2px;background:#58a6ff;display:inline-block"></span> CUSUM</span>
  <span class="leg-item"><span class="leg-swatch seg" style="width:22px;height:3px;background:#ffa657;display:inline-block"></span> Segment mean</span>
  <span class="leg-item"><span class="leg-swatch" style="width:2px;height:14px;background:#ff7b72;display:inline-block;border-radius:1px"></span> Change point</span>
  <span class="leg-item"><span class="leg-swatch" style="width:22px;height:0;border-top:1px dashed #484f58;display:inline-block"></span> Decadal boundary</span>
</div>

<div class="tooltip" id="tooltip"></div>

<script>
