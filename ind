const REG_COLORS={
 "Himalaya":"#58a6ff","Bhutan":"#f85149","Nepal":"#3fb950",
 "West Bengal":"#e3b341","Arunachal Pradesh":"#d2a8ff",
 "Himachal Pradesh":"#ffa657","Jammu and Kashmir":"#79c0ff",
 "Ladakh":"#56d364","Uttarakhand":"#ff9492","Sikkim":"#f0883e",
 "Western Himalaya":"#f85149","Central Himalaya":"#3fb950","Eastern Himalaya":"#d2a8ff"
};

let dataset='state', region='Himalaya', animFrame=0, playing=false, rafId=null, speed=4, lastTime=0;
const N=YEARS.length;

function getRegions(){return Object.keys(DATA[dataset]);}
function getData(){return DATA[dataset][region];}

function computeSegMeans(vals,cpts){
  const breaks=[0,...cpts,N];
  return breaks.slice(0,-1).map((s,i)=>{
    const e=breaks[i+1];
    const seg=vals.slice(s,e);
    return{start:s,end:e-1,mean:seg.reduce((a,b)=>a+b,0)/seg.length};
  });
}

function computeCUSUM(vals){
  const m=vals.reduce((a,b)=>a+b,0)/vals.length;
  let s=0;return vals.map(v=>(s+=v-m,s));
}

// ── Region buttons ──────────────────────────────────────
function buildRegionButtons(){
  const row=document.getElementById('region-row');
  row.innerHTML='';
  getRegions().forEach(r=>{
    const b=document.createElement('button');
    b.className='region-btn'+(r===region?' active':'');
    b.textContent=r;
    b.style.borderColor=r===region?REG_COLORS[r]:'';
    b.style.background=r===region?REG_COLORS[r]+'22':'';
    b.style.color=r===region?REG_COLORS[r]:'';
    b.onclick=()=>selectRegion(r);
    row.appendChild(b);
  });
}

function selectRegion(r){
  region=r; animFrame=0; playing=false;
  document.getElementById('play-btn').textContent='▶ Play Animation';
  buildRegionButtons(); updateSidebar(); redraw();
}

function switchDataset(ds,el){
  dataset=ds;
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  region=getRegions()[0]; animFrame=0; playing=false;
  document.getElementById('play-btn').textContent='▶ Play Animation';
  buildRegionButtons(); updateSidebar(); redraw();
}

// ── Sidebar stats ────────────────────────────────────────
function updateSidebar(){
  const {vals,cpts}=getData();
  const segs=computeSegMeans(vals,cpts);
  const m=vals.reduce((a,b)=>a+b,0)/N;
  const sd=Math.sqrt(vals.reduce((a,b)=>a+(b-m)**2,0)/N);
  const cpYears=cpts.map(i=>YEARS[i]);
  const trend=vals[N-1]-vals[0]>0?'Increasing':'Decreasing';
  let html=`
  <div class="stat-card"><div class="stat-label">REGION</div><div class="stat-value" style="font-size:.9rem;color:${REG_COLORS[region]}">${region}</div></div>
  <div class="stat-card"><div class="stat-label">MEAN ANOMALY</div><div class="stat-value">${m.toFixed(3)}</div></div>
  <div class="stat-card"><div class="stat-label">STD DEV</div><div class="stat-value">${sd.toFixed(3)}</div></div>
  <div class="stat-card"><div class="stat-label">CHANGE POINTS</div><div class="stat-value">${cpts.length}</div>
    <div style="margin-top:.35rem">${cpYears.map(y=>`<span class="cp-tag">${y}</span>`).join('')}</div>
  </div>
  <div class="stat-card"><div class="stat-label">SEGMENTS</div><div class="stat-value">${segs.length}</div>
    ${segs.map((s,i)=>{
      const dir=i>0?(s.mean>segs[i-1].mean?'up':'down'):null;
      return`<div style="font-size:.72rem;color:var(--muted);font-family:'JetBrains Mono',monospace;margin-top:.2rem">
        ${YEARS[s.start]}–${YEARS[s.end]}: <span style="color:${s.mean>=0?'#3fb950':'#f85149'}">${s.mean.toFixed(3)}</span>
        ${dir?`<span class="seg-change ${dir}">${dir==='up'?'↑':'↓'}</span>`:''}
      </div>`;
    }).join('')}
  </div>
  <div class="stat-card"><div class="stat-label">OVERALL TREND</div><div class="stat-value" style="font-size:.9rem;color:${trend==='Increasing'?'#3fb950':'#f85149'}">${trend}</div></div>
  `;
  document.getElementById('stat-cards').innerHTML=html;
}

// ── Canvas drawing ───────────────────────────────────────
const canvas=document.getElementById('c');
const ctx=canvas.getContext('2d');
const PAD={top:40,right:30,bottom:50,left:55};

function resize(){
  const area=document.getElementById('chart-area');
  canvas.width=area.clientWidth;
  canvas.height=area.clientHeight;
  redraw();
}

function redraw(){draw(animFrame);}

function draw(frame){
  const W=canvas.width, H=canvas.height;
  const {vals,cpts}=getData();
  const cusum=computeCUSUM(vals);
  const segs=computeSegMeans(vals,cpts);
  const showCusum=document.getElementById('show-cusum').checked;
  const showSeg=document.getElementById('show-seg').checked;
  const col=REG_COLORS[region];

  ctx.clearRect(0,0,W,H);

  const plotW=W-PAD.left-PAD.right;
  const plotH=H-PAD.top-PAD.bottom;
  const barW=plotW/N;

  // y-scale: both vals and cusum
  const allY=[...vals,...(showCusum?cusum:[])];
  const yMin=Math.min(...allY)*1.15, yMax=Math.max(...allY)*1.15;
  const yRange=yMax-yMin;

  const px=i=>PAD.left+(i+0.5)*barW;
  const py=v=>PAD.top+plotH-(v-yMin)/yRange*plotH;
  const y0=py(0);

  // Grid lines
  ctx.strokeStyle='#21262d'; ctx.lineWidth=1;
  [-2,-1,0,1,2,3,4].forEach(g=>{
    if(g<yMin||g>yMax)return;
    const y=py(g);
    ctx.beginPath();ctx.moveTo(PAD.left,y);ctx.lineTo(W-PAD.right,y);
    ctx.stroke();
    ctx.fillStyle='#484f58';ctx.font='10px JetBrains Mono,monospace';
    ctx.textAlign='right';ctx.fillText(g.toFixed(0),PAD.left-6,y+3.5);
  });

  // Decade dashed lines
  ctx.setLineDash([4,4]); ctx.strokeStyle='#484f58'; ctx.lineWidth=.8;
  [1990,2000,2010].forEach(yr=>{
    const xi=YEARS.indexOf(yr);
    if(xi<0)return;
    const x=PAD.left+xi*barW;
    ctx.beginPath();ctx.moveTo(x,PAD.top);ctx.lineTo(x,PAD.top+plotH);ctx.stroke();
    ctx.fillStyle='#484f58';ctx.font='9px JetBrains Mono,monospace';ctx.textAlign='center';
    ctx.fillText(yr,x,PAD.top-6);
  });
  ctx.setLineDash([]);

  // X-axis labels
  ctx.fillStyle='#8b949e';ctx.font='10px JetBrains Mono,monospace';ctx.textAlign='center';
  [1980,1985,1990,1995,2000,2005,2010,2015,2020].forEach(yr=>{
    const xi=YEARS.indexOf(yr);
    if(xi<0)return;
    ctx.fillText(yr,px(xi),PAD.top+plotH+18);
  });

  // Axis labels
  ctx.save();ctx.translate(14,PAD.top+plotH/2);ctx.rotate(-Math.PI/2);
  ctx.fillStyle='#8b949e';ctx.font='11px EB Garamond,serif';ctx.textAlign='center';
  ctx.fillText('Standardised Anomaly',0,0);ctx.restore();
  ctx.fillStyle='#8b949e';ctx.font='11px EB Garamond,serif';ctx.textAlign='center';
  ctx.fillText('Year',W/2,H-8);

  const count=Math.min(frame,N);

  // Bars (animated)
  for(let i=0;i<count;i++){
    const v=vals[i];
    const x=PAD.left+i*barW+barW*.1;
    const bw=barW*.8;
    const top=v>=0?py(v):y0;
    const bh=Math.abs(py(v)-y0);
    // Glow for large values
    if(Math.abs(v)>1.5){
      ctx.shadowColor=v>=0?'rgba(63,185,80,.4)':'rgba(248,81,73,.4)';
      ctx.shadowBlur=6;
    }
    ctx.fillStyle=v>=0?'#3fb950':'#f85149';
    ctx.globalAlpha=.85;
    ctx.fillRect(x,top,bw,Math.max(bh,1));
    ctx.globalAlpha=1; ctx.shadowBlur=0;
  }

  // Segment means (animated — draw up to current frame)
  if(showSeg){
    segs.forEach(s=>{
      if(s.start>=count)return;
      const end=Math.min(s.end,count-1);
      const x1=PAD.left+s.start*barW;
      const x2=PAD.left+(end+1)*barW;
      const y=py(s.mean);
      ctx.strokeStyle=col; ctx.lineWidth=2.5; ctx.setLineDash([]);
      ctx.beginPath();ctx.moveTo(x1,y);ctx.lineTo(x2,y);ctx.stroke();
      // Label
      if(end===s.end){
        ctx.fillStyle=col;ctx.font='bold 9px JetBrains Mono,monospace';ctx.textAlign='center';
        ctx.fillText(s.mean.toFixed(2),(x1+x2)/2,y-(s.mean>=0?8:-14));
      }
    });
  }

  // Change point lines (appear at their index)
  cpts.forEach(cp=>{
    if(cp>=count)return;
    const x=PAD.left+cp*barW;
    ctx.setLineDash([6,3]); ctx.strokeStyle='#ff7b72'; ctx.lineWidth=1.5;
    ctx.beginPath();ctx.moveTo(x,PAD.top);ctx.lineTo(x,PAD.top+plotH);ctx.stroke();
    ctx.setLineDash([]);
    // Year label badge
    const yr=YEARS[cp];
    ctx.fillStyle='rgba(255,123,114,.15)';
    const lw=ctx.measureText(yr).width+12;
    ctx.fillRect(x-lw/2,PAD.top+4,lw,16);
    ctx.strokeStyle='rgba(255,123,114,.5)';ctx.lineWidth=.6;
    ctx.strokeRect(x-lw/2,PAD.top+4,lw,16);
    ctx.fillStyle='#ff7b72';ctx.font='bold 9px JetBrains Mono,monospace';ctx.textAlign='center';
    ctx.fillText(yr,x,PAD.top+15);
  });

  // Zero line
  ctx.strokeStyle='#8b949e'; ctx.lineWidth=.8; ctx.setLineDash([]);
  ctx.beginPath();ctx.moveTo(PAD.left,y0);ctx.lineTo(W-PAD.right,y0);ctx.stroke();

  // CUSUM line (animated)
  if(showCusum&&count>1){
    ctx.strokeStyle='#58a6ff'; ctx.lineWidth=1.8; ctx.setLineDash([]);
    ctx.beginPath();
    for(let i=0;i<count;i++){
      if(i===0) ctx.moveTo(px(i),py(cusum[i]));
      else ctx.lineTo(px(i),py(cusum[i]));
    }
    ctx.stroke();
    // Dot at current position
    if(count<N){
      ctx.beginPath();ctx.arc(px(count-1),py(cusum[count-1]),3.5,0,Math.PI*2);
      ctx.fillStyle='#58a6ff';ctx.fill();
    }
  }

  // Region title
  ctx.fillStyle=col;ctx.font='bold 13px EB Garamond,serif';ctx.textAlign='left';
  ctx.fillText(region,PAD.left,PAD.top-16);
  ctx.fillStyle='#8b949e';ctx.font='10px JetBrains Mono,monospace';
  ctx.fillText(`${getData().cpts.length} change point(s) detected`,PAD.left+ctx.measureText(region).width+20,PAD.top-16);

  // Progress indicator
  document.getElementById('prog').style.width=((count/N)*100)+'%';
}

// ── Animation loop ───────────────────────────────────────
function animate(ts){
  if(!playing)return;
  const interval=1000/(speed*6);
  if(ts-lastTime>=interval){
    lastTime=ts;
    animFrame=Math.min(animFrame+1,N);
    draw(animFrame);
    if(animFrame>=N){playing=false;document.getElementById('play-btn').textContent='▶ Play Again';}
  }
  if(playing) rafId=requestAnimationFrame(animate);
}

function togglePlay(){
  if(animFrame>=N){animFrame=0;}
  playing=!playing;
  document.getElementById('play-btn').textContent=playing?'⏸ Pause':'▶ Play Animation';
  if(playing){lastTime=0;rafId=requestAnimationFrame(animate);}
  else{cancelAnimationFrame(rafId);}
}

function resetAnim(){
  playing=false; animFrame=0;
  cancelAnimationFrame(rafId);
  document.getElementById('play-btn').textContent='▶ Play Animation';
  draw(0);
}

function updateSpeed(v){speed=+v;document.getElementById('speed-label').textContent=v+'×';}

// ── Hover tooltip ────────────────────────────────────────
canvas.addEventListener('mousemove',e=>{
  const rect=canvas.getBoundingClientRect();
  const mx=e.clientX-rect.left, my=e.clientY-rect.top;
  const {vals,cpts}=getData();
  const plotW=canvas.width-PAD.left-PAD.right;
  const barW=plotW/N;
  const xi=Math.floor((mx-PAD.left)/barW);
  if(xi<0||xi>=N){document.getElementById('tooltip').style.opacity=0;return;}
  const yr=YEARS[xi], v=vals[xi];
  const isCpt=cpts.includes(xi);
  document.getElementById('tooltip').style.opacity=1;
  document.getElementById('tooltip').style.left=(e.clientX+12)+'px';
  document.getElementById('tooltip').style.top=(e.clientY-10)+'px';
  document.getElementById('tooltip').innerHTML=
    `<div style="color:#8b949e;font-size:.7rem">${yr}</div>`+
    `<div style="color:${v>=0?'#3fb950':'#f85149'};font-size:.9rem;font-weight:600">${v>=0?'+':''}${v.toFixed(4)}</div>`+
    (isCpt?`<div style="color:#ff7b72;font-size:.72rem;margin-top:.2rem">⚡ Change point</div>`:'');
});
canvas.addEventListener('mouseleave',()=>{document.getElementById('tooltip').style.opacity=0;});

// ── Init ─────────────────────────────────────────────────
window.addEventListener('resize',resize);
buildRegionButtons();
updateSidebar();
resize();
draw(N); // Show full data on load
</script>
